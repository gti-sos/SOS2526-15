            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{url}}/api/v1/population-densities"
      }
    },
    {
      "name": "5. POST-201",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"El país creado es francia\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.country).to.eql(\"francia\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\"country\": \"francia\",\"year\": 2024,\"density\": 105,\"population\": 68000000,\"percentage_change\": 0.3}"
        },
        "url": "{{url}}/api/v1/population-densities"
      }
    },
